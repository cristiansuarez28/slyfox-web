---
interface Props {
  title?: string;
  description?: string;
  image?: string;
  url?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
  modifiedTime?: string;
  author?: string;
  section?: string;
  tags?: string[];
}

const {
  title = 'Slyfox - Soluciones Digitales',
  description = 'Slyfox - Soluciones digitales innovadoras en desarrollo web, aplicaciones móviles y marketing digital en Colombia. Transformamos tus ideas en realidades digitales.',
  image = 'https://slyfox.com.co/images/og-image.jpg',
  url = 'https://slyfox.com.co',
  type = 'website',
  publishedTime = '',
  modifiedTime = '',
  author = '',
  section = '',
  tags = []
} = Astro.props;

const fullUrl = url.startsWith('http') ? url : new URL(url, 'https://slyfox.com.co').toString();
const fullImageUrl = image.startsWith('http') ? image : new URL(image, 'https://slyfox.com.co').toString();
const pageTitle = `${title} | Slyfox Colombia`;
---

<!-- Primary Meta Tags -->
<title>{pageTitle}</title>
<meta name="description" content={description} />
<meta name="keywords" content="desarrollo web Colombia, aplicaciones móviles, marketing digital, diseño UX UI, software a la medida, Slyfox, agencia digital Colombia" />
<meta name="author" content="Slyfox S.A.S" />
<meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
<meta name="language" content="es" />
<link rel="canonical" href={fullUrl} />
<link rel="alternate" hreflang="es-co" href={fullUrl} />
<link rel="alternate" hreflang="x-default" href={fullUrl} />

<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:url" content={fullUrl} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={fullImageUrl} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={title} />
<meta property="og:site_name" content="Slyfox" />
<meta property="og:locale" content="es_CO" />

{type === 'article' && (
  <>
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    {author && <meta property="article:author" content={author} />}
    {section && <meta property="article:section" content={section} />}
    {tags.map((tag: string) => (
      <meta property="article:tag" content={tag} />
    ))}
  </>
)}

<!-- Twitter / X -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={fullUrl} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={fullImageUrl} />
<meta name="twitter:image:alt" content={title} />
<meta name="twitter:site" content="@slyfoxco" />
<meta name="twitter:creator" content="@slyfoxco" />

<!-- Preconnect -->
<link rel="preconnect" href="https://www.googletagmanager.com" crossorigin />
