---
import AnimatedCounter from "@components/Shared/AnimatedCounter.astro";
---

<div class="w-full flex justify-center items-center md:hidden mt-7">
    <div class="grid grid-cols-2 w-[95%] gap-3 p-1">
        <div class="flex flex-col items-center">
            <h2
                class="text-[#FF7070] text-[45px] mr-6 font-bold font-inter leading-none
                sm:text-[65px] md:hidden"
            >
                +<AnimatedCounter target={50} />
            </h2>
            <p
                class="w-30 text-[#36455D] dark:text-[#F5F5F7] text-sm text-left
                font-bold font-inter mt-1 sm:text-base sm:w-50 md:hidden"
            >
                Empresas confían en nosotros
            </p>
        </div>
        <div class="flex flex-col items-center">
            <h2
                class="text-[#FF7070] text-[45px] font-bold font-inter leading-none
                sm:text-[65px] sm:text-center md:hidden"
            >
                +<AnimatedCounter target={100} />
            </h2>
            <p
                class="text-[#36455D] dark:text-[#F5F5F7] text-sm font-bold
                font-inter mt-3 sm:text-base sm:text-center md:hidden"
            >
                Proyectos Entregados
            </p>
        </div>
    </div>
</div>
