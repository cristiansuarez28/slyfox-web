---
import AnimatedCounter from "@components/Shared/AnimatedCounter.astro";
---

<div class="hidden md:flex md:items-stretch gap-0 max-w-[1400px] mx-auto px-4 sm:px-6 md:px-10 lg:px-16 my-10 lg:my-12 xl:my-16">

    <!-- Texto -->
    <div class="flex-1 flex items-center pr-10 lg:pr-16 xl:pr-20 border-r border-[#e5e5e5] dark:border-[#ffffff12]">
        <p class="text-left text-[#31323D] dark:text-[#ffffffcc] font-inter font-medium
                  text-base lg:text-lg xl:text-xl 2xl:text-2xl leading-relaxed">
            Nuestros clientes son nuestra mejor carta de presentación. Más que un servicio, ofrecemos soluciones tecnológicas que se adaptan a cada necesidad. Confiamos en la calidad, la innovación y el compromiso para hacer crecer tu negocio con software a la medida.
        </p>
    </div>

    <!-- Stat 1 -->
    <div class="flex flex-col justify-center pl-10 lg:pl-14 xl:pl-16 pr-10 lg:pr-14 xl:pr-16
                border-r border-[#e5e5e5] dark:border-[#ffffff12]">
        <div class="w-10 h-[3px] bg-[#FF7070] mb-4 rounded-full"></div>
        <p class="text-[#FF7070] font-inter font-bold leading-none
                  text-5xl lg:text-6xl xl:text-7xl">
            +<AnimatedCounter target={50} />
        </p>
        <p class="text-[#31323D] dark:text-[#ffffffaa] font-inter font-normal mt-3
                  text-sm lg:text-base xl:text-lg tracking-wide">
            Empresas confían<br />en nosotros
        </p>
    </div>

    <!-- Stat 2 -->
    <div class="flex flex-col justify-center pl-10 lg:pl-14 xl:pl-16">
        <div class="w-10 h-[3px] bg-[#FF7070] mb-4 rounded-full"></div>
        <p class="text-[#FF7070] font-inter font-bold leading-none
                  text-5xl lg:text-6xl xl:text-7xl">
            +<AnimatedCounter target={100} />
        </p>
        <p class="text-[#31323D] dark:text-[#ffffffaa] font-inter font-normal mt-3
                  text-sm lg:text-base xl:text-lg tracking-wide">
            Proyectos<br />Entregados
        </p>
    </div>

</div>
