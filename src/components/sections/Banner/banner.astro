---
import Stars from "@components/sections/Banner/bannerStars.astro"
import Customer from "@components/sections/Banner/bannerCustomer.astro"
import Phones from "@components/sections/Banner/bannerPhones.astro"
import Textmovile from "@components/sections/Banner/bannerDataMobile.astro"
import Textdesk from "@components/sections/Banner/bannerDataDesk.astro"
---

<section class="w-full flex flex-col items-center bg-[#fbfbfb] dark:bg-[#000000] pt-10 pb-10 sm:pt-12 sm:pb-12 md:pt-14 md:pb-14 lg:pt-16 lg:pb-12">
    <div class="w-full max-w-[1400px] mx-auto px-4 sm:px-6 md:px-10 lg:px-16 flex flex-col items-center">
        <h2 class="text-xl sm:text-2xl md:text-4xl lg:text-5xl xl:text-6xl font-bold font-inter text-center text-[#1E1E1E] dark:text-[#ffffffeb]">
            Lo hacemos por ti
        </h2>

        <div class="flex justify-center items-center gap-x-5 mt-8 sm:mt-10 md:mt-12">
            <Customer />
            <div class="flex flex-col justify-center">
                <Stars />
                <p
                    id="slide"
                    class="font-inter text-end text-sm sm:text-base md:text-lg text-[#1E1E1E] dark:text-[#ffffffeb] mt-1 mr-2 sm:mr-4"
                >
                    Clientes de Confianza
                </p>
            </div>
        </div>
    </div>
</section>

<section class="w-full bg-[#fbfbfb] dark:bg-[#000000]">
    <Phones />
    <Textdesk />
    <Textmovile />
</section>

<style>
    #slide {
        animation: slide-up 1.8s cubic-bezier(.25,.46,.45,.94) both;
    }

    @keyframes slide-up {
        0%   { transform: translateY(200px); opacity: 0; }
        40%  { opacity: 0.5; }
        70%  { opacity: 0.9; }
        100% { transform: translateY(0); opacity: 1; }
    }
</style>
