---
import React from "@images/react.webp"
import Nestjs from "@images/nestjs-icon-2.webp"
import Aws from "@images/aws.webp"
import Nodejs from "@images/node_js.webp"
import Js from "@images/js.webp"
import Ai from "@images/adobe_illustrator.webp"
import Vue from "@images/vue.webp"
import Angular from "@images/angular.webp"
import Html from "@images/html_5.webp"
import Oracle from "@images/oracle.webp"
import Tailwind from "@images/twain.webp"
import Mongodb from "@images/mongos.webp"
import Css from "@images/css_3.webp"
import Figma from "@images/figma.webp"

import { Image } from "astro:assets";

export const imagenes = [
    {src: Figma,   alt: "Figma",              title: "Figma"},
    {src: React,   alt: "React",              title: "React"},
    {src: Aws,     alt: "Amazon Web Services", title: "AWS"},
    {src: Nodejs,  alt: "Node.js",             title: "Node.js"},
    {src: Nestjs,  alt: "NestJS",              title: "NestJS"},
    {src: Js,      alt: "JavaScript",          title: "JavaScript"},
    {src: Ai,      alt: "Adobe Illustrator",   title: "Adobe Illustrator"},
    {src: Vue,     alt: "Vue.js",              title: "Vue.js"},
    {src: Angular, alt: "Angular",             title: "Angular"},
    {src: Html,    alt: "HTML5",               title: "HTML5"},
    {src: Oracle,  alt: "Oracle Database",     title: "Oracle"},
    {src: Tailwind,alt: "Tailwind CSS",        title: "Tailwind CSS"},
    {src: Mongodb, alt: "MongoDB",             title: "MongoDB"},
    {src: Css,     alt: "CSS3",                title: "CSS3"},
]
---

<!-- ── MOBILE: marquee 2 filas (solo < md) ── -->
<div class="mob-marquee-wrap md:hidden mt-8" aria-hidden="true">

    <!-- Fila 1 → izquierda -->
    <div class="mob-marquee-track">
        <div class="mob-marquee-row row-left">
            {[...imagenes, ...imagenes].map((img) => (
                <div class="mob-chip">
                    <Image src={img.src} alt={img.alt} class="mob-chip-img object-contain" />
                    <span class="mob-chip-label">{img.title}</span>
                </div>
            ))}
        </div>
    </div>

    <!-- Fila 2 → derecha -->
    <div class="mob-marquee-track">
        <div class="mob-marquee-row row-right">
            {[...imagenes.slice(6), ...imagenes, ...imagenes.slice(0,6)].map((img) => (
                <div class="mob-chip">
                    <Image src={img.src} alt={img.alt} class="mob-chip-img object-contain" />
                    <span class="mob-chip-label">{img.title}</span>
                </div>
            ))}
        </div>
    </div>

</div>

<!-- ── DESKTOP / TABLET: cards con nombre, sin Figma (aparece arriba) ── -->
<div class="desk-grid">
    {imagenes.filter(img => img.title !== 'Figma').map((img) => (
        <div class="desk-card">
            <div class="desk-icon-wrap">
                <Image
                    src={img.src}
                    alt={img.alt}
                    title={img.title}
                    class="desk-img object-contain"
                />
            </div>
            <span class="desk-label">{img.title}</span>
        </div>
    ))}
</div>

<style>
/* ══ MOBILE marquee — solo < 768px ══ */
.mob-marquee-wrap {
    display: flex;
    flex-direction: column;
    gap: 12px;
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent, black 12%, black 88%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 12%, black 88%, transparent);
}

.mob-marquee-track {
    overflow: hidden;
    width: 100%;
}

.mob-marquee-row {
    display: flex;
    gap: 10px;
    width: max-content;
}

.row-left  { animation: marquee-left  28s linear infinite; }
.row-right { animation: marquee-right 24s linear infinite; }

@keyframes marquee-left {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
}
@keyframes marquee-right {
    0%   { transform: translateX(-50%); }
    100% { transform: translateX(0); }
}

/* Pausa al tocar */
.mob-marquee-wrap:hover .mob-marquee-row,
.mob-marquee-wrap:active .mob-marquee-row {
    animation-play-state: paused;
}

/* Chip individual */
.mob-chip {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 8px 14px;
    border-radius: 100px;
    background: rgba(255,255,255,0.9);
    border: 1px solid rgba(0,0,0,0.07);
    box-shadow: 0 1px 4px rgba(0,0,0,0.07);
    white-space: nowrap;
    flex-shrink: 0;
}

:global(.dark) .mob-chip {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.08);
    box-shadow: none;
}

.mob-chip-img {
    width: 22px;
    height: 22px;
    object-fit: contain;
    flex-shrink: 0;
}

.mob-chip-label {
    font-size: 12px;
    font-weight: 600;
    color: #333;
    font-family: var(--font-inter, sans-serif);
    letter-spacing: -0.01em;
}

:global(.dark) .mob-chip-label {
    color: #c8c8cc;
}

/* ══ DESKTOP cards ══ */
.desk-grid {
    display: none;
    width: 100%;
}

@media (min-width: 768px) {
    .mob-marquee-wrap { display: none; }
    .desk-grid {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 16px;
        margin-top: 48px;
    }
}

@media (min-width: 1024px) { .desk-grid { gap: 20px; margin-top: 64px; } }
@media (min-width: 1280px) { .desk-grid { gap: 24px; margin-top: 80px; } }

.desk-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    padding: 20px 16px 16px;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.6);
    border: 1px solid rgba(0, 0, 0, 0.06);
    width: calc(20% - 14px);
    min-width: 110px;
    max-width: 160px;
    cursor: pointer;
    transition: transform 0.22s cubic-bezier(0.34, 1.56, 0.64, 1),
                box-shadow 0.22s ease;
}

:global(.dark) .desk-card {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.07);
}

.desk-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.12);
}

:global(.dark) .desk-card:hover {
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.5);
}

.desk-icon-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
}

@media (min-width: 1024px) { .desk-icon-wrap { width: 68px; height: 68px; } }
@media (min-width: 1280px) { .desk-icon-wrap { width: 80px; height: 80px; } }

.desk-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
}

.desk-label {
    font-size: 11px;
    font-weight: 600;
    color: #555;
    font-family: var(--font-inter, sans-serif);
    letter-spacing: 0.01em;
    text-align: center;
}

@media (min-width: 1024px) { .desk-label { font-size: 12px; } }
@media (min-width: 1280px) { .desk-label { font-size: 13px; } }

:global(.dark) .desk-label { color: #86868B; }
</style>
