---
import Logo from "@components/Shared/Logo.astro";
import Redes from "@components/sections/footer/Redes.astro";
import FooterTextos from "./footerTextos.astro";
import FooterInfo from "@components/sections/footer/footerInfo.astro"
---

<footer id="contacto" class="w-full bg-[#F5F6FA] dark:bg-[#0D0D0D] mt-10 text-[#31323D] dark:text-[#F5F5F7]">

    <!-- Contenido principal -->
    <div class="max-w-[1400px] mx-auto px-4 sm:px-6 md:px-10 lg:px-16 py-8 md:py-10 lg:py-14
                flex flex-row items-start justify-between gap-4">

        <!-- Logo + textos -->
        <div class="flex flex-col gap-3 flex-1 min-w-0">
            <Logo className="w-[70px] sm:w-[110px] md:w-[140px] lg:w-[170px] xl:w-[190px]" />
            <FooterTextos />
        </div>

        <!-- Redes sociales -->
        <div class="flex flex-col items-center justify-start flex-shrink-0">
            <Redes />
        </div>
    </div>

    <!-- Barra inferior -->
    <div class="border-t border-[#e5e5e5] dark:border-[#ffffff15]">
        <FooterInfo />
    </div>

</footer>
